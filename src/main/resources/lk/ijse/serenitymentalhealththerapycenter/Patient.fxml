<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:id="contentRoot" prefHeight="610.0" prefWidth="920.0" spacing="16.0" style="-fx-background-color: #f0fdf4; -fx-padding: 20 30 20 30;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.serenitymentalhealththerapycenter.controller.PatientController">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" prefHeight="50.0" spacing="10.0">
        <children>
            <Label text="Patients" textFill="#1f2937">
                <font><Font name="Arial Bold" size="28.0" /></font>
            </Label>
            <Pane HBox.hgrow="ALWAYS" />
            <TextField fx:id="txtSearch" prefHeight="38.0" prefWidth="220.0" promptText="🔍 Search patients..." style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #6ee7b7; -fx-border-radius: 10; -fx-padding: 0 12 0 12; -fx-font-size: 13px;" />
            <Button fx:id="btnAddNew" prefHeight="38.0" prefWidth="130.0" style="-fx-background-color: #10b981; -fx-background-radius: 10; -fx-text-fill: white; -fx-font-family: 'Arial'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;" text="➕ Add New">
                <font><Font name="Arial Bold" size="13.0" /></font>
            </Button>
        </children>
    </HBox>

    <!-- Form Card -->
    <VBox spacing="14.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 4);">
        <padding>
            <Insets bottom="18.0" left="22.0" right="22.0" top="18.0" />
        </padding>
        <children>
            <Label text="Patient Registration" textFill="#1f2937">
                <font><Font name="Arial Bold" size="16.0" /></font>
            </Label>

            <GridPane hgap="16.0" vgap="12.0" VBox.vgrow="NEVER">
                <columnConstraints>
                    <ColumnConstraints hgrow="ALWAYS" minWidth="120.0" percentWidth="16.6" />
                    <ColumnConstraints hgrow="ALWAYS" minWidth="120.0" percentWidth="16.6" />
                    <ColumnConstraints hgrow="ALWAYS" minWidth="120.0" percentWidth="16.6" />
                    <ColumnConstraints hgrow="ALWAYS" minWidth="120.0" percentWidth="16.6" />
                    <ColumnConstraints hgrow="ALWAYS" minWidth="120.0" percentWidth="16.6" />
                    <ColumnConstraints hgrow="ALWAYS" minWidth="120.0" percentWidth="16.6" />
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints minHeight="30.0" vgrow="NEVER" />
                    <RowConstraints minHeight="42.0" vgrow="NEVER" />
                    <RowConstraints minHeight="30.0" vgrow="NEVER" />
                    <RowConstraints minHeight="42.0" vgrow="NEVER" />
                    <RowConstraints minHeight="30.0" vgrow="NEVER" />
                    <RowConstraints minHeight="80.0" vgrow="NEVER" />
                </rowConstraints>

                <Label text="Patient ID" textFill="#374151" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <font><Font name="Arial Bold" size="12.0" /></font>
                </Label>
                <Label text="Full Name" textFill="#374151" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <font><Font name="Arial Bold" size="12.0" /></font>
                </Label>
                <Label text="NIC" textFill="#374151" GridPane.columnIndex="2" GridPane.rowIndex="0">
                    <font><Font name="Arial Bold" size="12.0" /></font>
                </Label>
                <Label text="Date of Birth" textFill="#374151" GridPane.columnIndex="3" GridPane.rowIndex="0">
                    <font><Font name="Arial Bold" size="12.0" /></font>
                </Label>
                <Label text="Gender" textFill="#374151" GridPane.columnIndex="4" GridPane.rowIndex="0">
                    <font><Font name="Arial Bold" size="12.0" /></font>
                </Label>
                <Label text="Phone" textFill="#374151" GridPane.columnIndex="5" GridPane.rowIndex="0">
                    <font><Font name="Arial Bold" size="12.0" /></font>
                </Label>

                <TextField fx:id="txtPatientId" prefHeight="32.0" promptText="P001" style="-fx-background-color: #d1fae5; -fx-background-radius: 10; -fx-border-color: #6ee7b7; -fx-border-radius: 10; -fx-padding: 0 0 0 12; -fx-font-size: 13px;" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <TextField fx:id="txtPatientName" prefHeight="32.0" promptText="John Doe" style="-fx-background-color: #d1fae5; -fx-background-radius: 10; -fx-border-color: #6ee7b7; -fx-border-radius: 10; -fx-padding: 0 0 0 12; -fx-font-size: 13px;" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                <TextField fx:id="txtNic" prefHeight="32.0" promptText="2000XXXXXXX" style="-fx-background-color: #d1fae5; -fx-background-radius: 10; -fx-border-color: #6ee7b7; -fx-border-radius: 10; -fx-padding: 0 0 0 12; -fx-font-size: 13px;" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                <DatePicker fx:id="dpDob" prefHeight="32.0" style="-fx-background-color: #d1fae5; -fx-background-radius: 10; -fx-border-color: #6ee7b7; -fx-border-radius: 10; -fx-font-size: 13px;" GridPane.columnIndex="3" GridPane.rowIndex="1" />
                <ComboBox fx:id="cmbGender" prefHeight="32.0" prefWidth="126.0" style="-fx-background-color: #d1fae5; -fx-border-color: #6ee7b7; -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-size: 13px;" GridPane.columnIndex="4" GridPane.rowIndex="1" />
                <TextField fx:id="txtPatientPhone" prefHeight="32.0" promptText="07X XXX XXXX" style="-fx-background-color: #d1fae5; -fx-background-radius: 10; -fx-border-color: #6ee7b7; -fx-border-radius: 10; -fx-padding: 0 0 0 12; -fx-font-size: 13px;" GridPane.columnIndex="5" GridPane.rowIndex="1" />

                <Label text="Email" textFill="#374151" GridPane.columnIndex="0" GridPane.rowIndex="2">
                    <font><Font name="Arial Bold" size="12.0" /></font>
                </Label>
                <Label text="Address" textFill="#374151" GridPane.columnIndex="1" GridPane.rowIndex="2">
                    <font><Font name="Arial Bold" size="12.0" /></font>
                </Label>
                <Label text="Emergency Contact" textFill="#374151" GridPane.columnIndex="2" GridPane.rowIndex="2">
                    <font><Font name="Arial Bold" size="12.0" /></font>
                </Label>
                <Label text="Therapy Program" textFill="#374151" GridPane.columnIndex="3" GridPane.rowIndex="2">
                    <font><Font name="Arial Bold" size="12.0" /></font>
                </Label>
                <Label text="Registration Date" textFill="#374151" GridPane.columnIndex="4" GridPane.rowIndex="2">
                    <font><Font name="Arial Bold" size="12.0" /></font>
                </Label>

                <TextField fx:id="txtPatientEmail" prefHeight="32.0" promptText="patient@email.com" style="-fx-background-color: #d1fae5; -fx-background-radius: 10; -fx-border-color: #6ee7b7; -fx-border-radius: 10; -fx-padding: 0 0 0 12; -fx-font-size: 13px;" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                <TextField fx:id="txtAddress" prefHeight="32.0" promptText="No. 123, Colombo" style="-fx-background-color: #d1fae5; -fx-background-radius: 10; -fx-border-color: #6ee7b7; -fx-border-radius: 10; -fx-padding: 0 0 0 12; -fx-font-size: 13px;" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                <TextField fx:id="txtEmergencyContact" prefHeight="32.0" promptText="07X XXX XXXX" style="-fx-background-color: #d1fae5; -fx-background-radius: 10; -fx-border-color: #6ee7b7; -fx-border-radius: 10; -fx-padding: 0 0 0 12; -fx-font-size: 13px;" GridPane.columnIndex="2" GridPane.rowIndex="3" />
                <ComboBox fx:id="cmbTherapyProgram" prefHeight="32.0" prefWidth="146.0" style="-fx-background-color: #d1fae5; -fx-border-color: #6ee7b7; -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-size: 13px;" GridPane.columnIndex="3" GridPane.rowIndex="3" />
                <DatePicker fx:id="dpRegistrationDate" prefHeight="32.0" style="-fx-background-color: #d1fae5; -fx-background-radius: 10; -fx-border-color: #6ee7b7; -fx-border-radius: 10; -fx-font-size: 13px;" GridPane.columnIndex="4" GridPane.rowIndex="3" />

                <Label text="Medical History" textFill="#374151" GridPane.columnIndex="0" GridPane.rowIndex="4">
                    <font><Font name="Arial Bold" size="12.0" /></font>
                </Label>

                <TextArea fx:id="txtMedicalHistory" promptText="Enter medical history and notes..." style="-fx-background-color: #d1fae5; -fx-background-radius: 10; -fx-border-color: #6ee7b7; -fx-border-radius: 10; -fx-padding: 8 12 8 12; -fx-font-size: 13px;" wrapText="true" GridPane.columnIndex="0" GridPane.columnSpan="6" GridPane.rowIndex="5" />
            </GridPane>

            <HBox alignment="CENTER_RIGHT" spacing="10.0" style="-fx-padding: 6 0 0 0;">
                <children>
                    <Button fx:id="btnSave" prefHeight="36.0" prefWidth="90.0" style="-fx-background-color: #10b981; -fx-background-radius: 10; -fx-text-fill: white; -fx-font-family: 'Arial'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;" text="💾 Save">
                        <font><Font name="Arial Bold" size="13.0" /></font>
                    </Button>
                    <Button fx:id="btnUpdate" prefHeight="36.0" prefWidth="90.0" style="-fx-background-color: #f59e0b; -fx-background-radius: 10; -fx-text-fill: white; -fx-font-family: 'Arial'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;" text="✏️ Update">
                        <font><Font name="Arial Bold" size="13.0" /></font>
                    </Button>
                    <Button fx:id="btnDelete" prefHeight="36.0" prefWidth="90.0" style="-fx-background-color: #ef4444; -fx-background-radius: 10; -fx-text-fill: white; -fx-font-family: 'Arial'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;" text="🗑️ Delete">
                        <font><Font name="Arial Bold" size="13.0" /></font>
                    </Button>
                    <Button fx:id="btnClear" prefHeight="36.0" prefWidth="90.0" style="-fx-background-color: #6b7280; -fx-background-radius: 10; -fx-text-fill: white; -fx-font-family: 'Arial'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;" text="🔄 Clear">
                        <font><Font name="Arial Bold" size="13.0" /></font>
                    </Button>
                </children>
            </HBox>
        </children>
    </VBox>

    <!-- Table Card -->
    <VBox spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 4);" VBox.vgrow="ALWAYS">
        <padding>
            <Insets bottom="18.0" left="22.0" right="22.0" top="18.0" />
        </padding>
        <children>
            <Label text="All Patients" textFill="#1f2937">
                <font><Font name="Arial Bold" size="16.0" /></font>
            </Label>

            <TableView fx:id="tblPatients" style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #e5e7eb;" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colPatientId" prefWidth="70.0" text="ID" />
                    <TableColumn fx:id="colPatientName" prefWidth="140.0" text="Name" />
                    <TableColumn fx:id="colNic" prefWidth="100.0" text="NIC" />
                    <TableColumn fx:id="colPhone" prefWidth="100.0" text="Phone" />
                    <TableColumn fx:id="colProgram" prefWidth="140.0" text="Program" />
                    <TableColumn fx:id="colRegDate" prefWidth="100.0" text="Reg. Date" />
                    <TableColumn fx:id="colStatus" prefWidth="90.0" text="Status" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
        </children>
    </VBox>
</VBox>
