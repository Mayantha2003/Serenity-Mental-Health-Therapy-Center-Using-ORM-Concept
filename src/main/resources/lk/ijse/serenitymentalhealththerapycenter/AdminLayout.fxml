<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="800.0" prefWidth="920.0" style="-fx-background-color: #f0fdf4;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.serenitymentalhealththerapycenter.controller.AdminLayoutController">
    <children>
        <AnchorPane prefHeight="800.0" prefWidth="1100.0" style="-fx-background-color: #f0fdf4;">
            <children>

                <!-- ═══════ SIDEBAR ═══════ -->
                <VBox alignment="TOP_CENTER" prefWidth="230.0" style="-fx-background-color: linear-gradient(to bottom, #10b981, #059669); -fx-background-radius: 15;" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.topAnchor="10.0">
                    <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                    </padding>
                    <children>

                        <!-- Logo -->
                        <VBox alignment="CENTER" spacing="4.0">
                            <padding><Insets bottom="10.0" top="10.0" /></padding>
                            <children>
                                <Label style="-fx-font-size: 34px;" text="🌿" />
                                <Label text="Serenity" textFill="white">
                                    <font><Font name="Arial Bold" size="22.0" /></font>
                                </Label>
                                <Label text="Mental Health Center" textFill="#a7f3d0">
                                    <font><Font name="Arial" size="10.0" /></font>
                                </Label>
                            </children>
                        </VBox>

                        <Region prefHeight="16.0" />

                        <!-- Date & Time -->
                        <Label fx:id="lblDate" text="Date" textFill="#d1fae5">
                            <font><Font name="Arial" size="11.0" /></font>
                        </Label>
                        <Label fx:id="lblTime" text="Time" textFill="#d1fae5">
                            <font><Font name="Arial" size="11.0" /></font>
                            <VBox.margin><Insets bottom="14.0" /></VBox.margin>
                        </Label>

                        <!-- Nav Buttons -->
                        <Button fx:id="btnDashboard" maxWidth="1.7976931348623157E308" prefHeight="42.0" style="-fx-background-color: rgba(255,255,255,0.18); -fx-background-radius: 10; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 16;" text="🏠  Dashboard">
                            <font><Font name="Arial Bold" size="13.0" /></font>
                            <VBox.margin><Insets bottom="6.0" /></VBox.margin>
                        </Button>

                        <Button fx:id="btnTherapists" maxWidth="1.7976931348623157E308" prefHeight="42.0" style="-fx-background-color: transparent; -fx-background-radius: 10; -fx-text-fill: #d1fae5; -fx-font-size: 13px; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 16;" text="👨‍⚕️  Therapists">
                            <font><Font name="Arial" size="13.0" /></font>
                            <VBox.margin><Insets bottom="6.0" /></VBox.margin>
                        </Button>

                        <Button fx:id="btnPrograms" maxWidth="1.7976931348623157E308" prefHeight="42.0" style="-fx-background-color: transparent; -fx-background-radius: 10; -fx-text-fill: #d1fae5; -fx-font-size: 13px; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 16;" text="📋  Therapy Programs">
                            <font><Font name="Arial" size="13.0" /></font>
                            <VBox.margin><Insets bottom="6.0" /></VBox.margin>
                        </Button>

                        <Button fx:id="btnPatients" maxWidth="1.7976931348623157E308" prefHeight="42.0" style="-fx-background-color: transparent; -fx-background-radius: 10; -fx-text-fill: #d1fae5; -fx-font-size: 13px; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 16;" text="🧑‍⚕️  Patients">
                            <font><Font name="Arial" size="13.0" /></font>
                            <VBox.margin><Insets bottom="6.0" /></VBox.margin>
                        </Button>

                        <Button fx:id="btnSchedule" maxWidth="1.7976931348623157E308" prefHeight="42.0" style="-fx-background-color: transparent; -fx-background-radius: 10; -fx-text-fill: #d1fae5; -fx-font-size: 13px; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 16;" text="📅  Schedule Sessions">
                            <font><Font name="Arial" size="13.0" /></font>
                            <VBox.margin><Insets bottom="6.0" /></VBox.margin>
                        </Button>

                        <Button fx:id="btnPayments" maxWidth="1.7976931348623157E308" prefHeight="42.0" style="-fx-background-color: transparent; -fx-background-radius: 10; -fx-text-fill: #d1fae5; -fx-font-size: 13px; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 16;" text="💳  Payments">
                            <font><Font name="Arial" size="13.0" /></font>
                            <VBox.margin><Insets bottom="6.0" /></VBox.margin>
                        </Button>

                        <Button fx:id="btnReports" maxWidth="1.7976931348623157E308" prefHeight="42.0" style="-fx-background-color: transparent; -fx-background-radius: 10; -fx-text-fill: #d1fae5; -fx-font-size: 13px; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 16;" text="📊  Reports">
                            <font><Font name="Arial" size="13.0" /></font>
                        </Button>

                        <Region VBox.vgrow="ALWAYS" />

                        <!-- User Profile -->
                        <VBox alignment="CENTER" spacing="5.0" style="-fx-background-color: rgba(0,0,0,0.12); -fx-background-radius: 10; -fx-padding: 12 0 12 0;">
                            <children>
                                <Circle fill="#a7f3d0" radius="18.0" stroke="white" strokeWidth="2.0" />
                                <Label fx:id="lblUsername" text="Admin User" textFill="white">
                                    <font><Font name="Arial Bold" size="13.0" /></font>
                                </Label>
                                <Label fx:id="lblRole" text="Administrator" textFill="#a7f3d0">
                                    <font><Font name="Arial" size="11.0" /></font>
                                </Label>
                                <Button fx:id="btnLogout" prefHeight="28.0" prefWidth="110.0" style="-fx-background-color: rgba(255,255,255,0.2); -fx-background-radius: 14; -fx-text-fill: white; -fx-font-size: 11px; -fx-cursor: hand;" text="🚪 Logout">
                                    <font><Font name="Arial Bold" size="11.0" /></font>
                                </Button>
                            </children>
                        </VBox>

                    </children>
                </VBox>

                <!-- ═══════ MAIN CONTENT AREA ═══════ -->
                <StackPane fx:id="main_Form" style="-fx-background-color: #f0fdf4; -fx-background-radius: 12;" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="250.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0" />

            </children>
        </AnchorPane>
    </children>
</StackPane>
