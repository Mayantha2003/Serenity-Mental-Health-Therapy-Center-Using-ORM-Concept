<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:id="contentRoot" prefHeight="644.0" prefWidth="1109.0" spacing="16.0" style="-fx-background-color: #f0fdf4; -fx-padding: 20 30 20 30;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.serenitymentalhealththerapycenter.controller.ProgramController">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" prefHeight="50.0" spacing="10.0">
        <children>
            <Label text="Therapy Programs" textFill="#1f2937">
                <font><Font name="Arial Bold" size="28.0" /></font>
            </Label>
            <Pane HBox.hgrow="ALWAYS" />
            <TextField fx:id="txtSearch" prefHeight="38.0" prefWidth="220.0" promptText="🔍 Search programs..." style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #6ee7b7; -fx-border-radius: 10; -fx-padding: 0 12 0 12; -fx-font-size: 13px;" />
            <Button fx:id="btnAddNew" prefHeight="38.0" prefWidth="130.0" style="-fx-background-color: #10b981; -fx-background-radius: 10; -fx-text-fill: white; -fx-font-family: 'Arial'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;" text="➕ Add New">
                <font><Font name="Arial Bold" size="13.0" /></font>
            </Button>
        </children>
    </HBox>

    <!-- Form Card -->
    <VBox spacing="14.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 4);">
        <padding>
            <Insets bottom="18.0" left="22.0" right="22.0" top="18.0" />
        </padding>
        <children>
            <Label text="Program Details" textFill="#1f2937">
                <font><Font name="Arial Bold" size="16.0" /></font>
            </Label>

            <GridPane hgap="16.0" vgap="12.0" VBox.vgrow="NEVER">
                <columnConstraints>
                    <ColumnConstraints hgrow="ALWAYS" minWidth="150.0" percentWidth="20.0" />
                    <ColumnConstraints hgrow="ALWAYS" minWidth="150.0" percentWidth="25.0" />
                    <ColumnConstraints hgrow="ALWAYS" minWidth="150.0" percentWidth="15.0" />
                    <ColumnConstraints hgrow="ALWAYS" minWidth="150.0" percentWidth="20.0" />
                    <ColumnConstraints hgrow="ALWAYS" minWidth="150.0" percentWidth="20.0" />
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints minHeight="30.0" vgrow="NEVER" />
                    <RowConstraints minHeight="42.0" vgrow="NEVER" />
                    <RowConstraints minHeight="30.0" vgrow="NEVER" />
                    <RowConstraints minHeight="80.0" vgrow="NEVER" />
                </rowConstraints>

                <Label text="Program ID" textFill="#374151" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <font><Font name="Arial Bold" size="12.0" /></font>
                </Label>
                <Label text="Program Name" textFill="#374151" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <font><Font name="Arial Bold" size="12.0" /></font>
                </Label>
                <Label text="Duration" textFill="#374151" GridPane.columnIndex="2" GridPane.rowIndex="0">
                    <font><Font name="Arial Bold" size="12.0" /></font>
                </Label>
                <Label text="Fee (LKR)" textFill="#374151" GridPane.columnIndex="3" GridPane.rowIndex="0">
                    <font><Font name="Arial Bold" size="12.0" /></font>
                </Label>
                <Label text="Assigned Therapist" textFill="#374151" GridPane.columnIndex="4" GridPane.rowIndex="0">
                    <font><Font name="Arial Bold" size="12.0" /></font>
                </Label>

                <TextField fx:id="txtProgramId" prefHeight="92.0" promptText="MT1001" style="-fx-background-color: #d1fae5; -fx-background-radius: 10; -fx-border-color: #6ee7b7; -fx-border-radius: 10; -fx-padding: 0 0 0 12; -fx-font-size: 13px;" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <TextField fx:id="txtProgramName" prefHeight="92.0" promptText="Cognitive Behavioral Therapy" style="-fx-background-color: #d1fae5; -fx-background-radius: 10; -fx-border-color: #6ee7b7; -fx-border-radius: 10; -fx-padding: 0 0 0 12; -fx-font-size: 13px;" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                <TextField fx:id="txtDuration" prefHeight="92.0" promptText="12 weeks" style="-fx-background-color: #d1fae5; -fx-background-radius: 10; -fx-border-color: #6ee7b7; -fx-border-radius: 10; -fx-padding: 0 0 0 12; -fx-font-size: 13px;" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                <TextField fx:id="txtFee" prefHeight="92.0" promptText="80000.00" style="-fx-background-color: #d1fae5; -fx-background-radius: 10; -fx-border-color: #6ee7b7; -fx-border-radius: 10; -fx-padding: 0 0 0 12; -fx-font-size: 13px;" GridPane.columnIndex="3" GridPane.rowIndex="1" />
                <TextField fx:id="txtAssignedTherapist" prefHeight="92.0" promptText="Select therapist" style="-fx-background-color: #d1fae5; -fx-background-radius: 10; -fx-border-color: #6ee7b7; -fx-border-radius: 10; -fx-padding: 0 0 0 12; -fx-font-size: 13px;" GridPane.columnIndex="4" GridPane.rowIndex="1" />

                <Label text="Description" textFill="#374151" GridPane.columnIndex="0" GridPane.rowIndex="2">
                    <font><Font name="Arial Bold" size="12.0" /></font>
                </Label>

                <TextArea fx:id="txtDescription" promptText="Enter program description..." style="-fx-background-color: #d1fae5; -fx-background-radius: 10; -fx-border-color: #6ee7b7; -fx-border-radius: 10; -fx-padding: 8 12 8 12; -fx-font-size: 13px;" wrapText="true" GridPane.columnSpan="5" GridPane.rowIndex="3" />
            </GridPane>

            <HBox alignment="CENTER_RIGHT" spacing="10.0" style="-fx-padding: 6 0 0 0;">
                <children>
                    <Button fx:id="btnSave" prefHeight="36.0" prefWidth="90.0" style="-fx-background-color: #10b981; -fx-background-radius: 10; -fx-text-fill: white; -fx-font-family: 'Arial'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;" text="💾 Save">
                        <font><Font name="Arial Bold" size="13.0" /></font>
                    </Button>
                    <Button fx:id="btnUpdate" prefHeight="36.0" prefWidth="90.0" style="-fx-background-color: #f59e0b; -fx-background-radius: 10; -fx-text-fill: white; -fx-font-family: 'Arial'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;" text="✏️ Update">
                        <font><Font name="Arial Bold" size="13.0" /></font>
                    </Button>
                    <Button fx:id="btnDelete" prefHeight="36.0" prefWidth="90.0" style="-fx-background-color: #ef4444; -fx-background-radius: 10; -fx-text-fill: white; -fx-font-family: 'Arial'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;" text="🗑️ Delete">
                        <font><Font name="Arial Bold" size="13.0" /></font>
                    </Button>
                    <Button fx:id="btnClear" prefHeight="36.0" prefWidth="90.0" style="-fx-background-color: #6b7280; -fx-background-radius: 10; -fx-text-fill: white; -fx-font-family: 'Arial'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;" text="🔄 Clear">
                        <font><Font name="Arial Bold" size="13.0" /></font>
                    </Button>
                </children>
            </HBox>
        </children>
    </VBox>

    <!-- Table Card -->
    <VBox spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 4);" VBox.vgrow="ALWAYS">
        <padding>
            <Insets bottom="18.0" left="22.0" right="22.0" top="18.0" />
        </padding>
        <children>
            <Label text="All Therapy Programs" textFill="#1f2937">
                <font><Font name="Arial Bold" size="16.0" /></font>
            </Label>

            <TableView fx:id="tblPrograms" style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #e5e7eb;" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colProgramId" prefWidth="90.0" text="Program ID" />
                    <TableColumn fx:id="colProgramName" prefWidth="200.0" text="Program Name" />
                    <TableColumn fx:id="colDuration" prefWidth="100.0" text="Duration" />
                    <TableColumn fx:id="colFee" prefWidth="100.0" text="Fee (LKR)" />
                    <TableColumn fx:id="colTherapist" prefWidth="150.0" text="Therapist" />
                    <TableColumn fx:id="colDescription" prefWidth="200.0" text="Description" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
        </children>
    </VBox>

</VBox>
