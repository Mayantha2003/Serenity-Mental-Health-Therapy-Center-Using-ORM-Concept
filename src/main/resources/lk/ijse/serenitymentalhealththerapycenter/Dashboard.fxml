<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane style="-fx-background-color: #f0fdf4;"
           xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="lk.ijse.serenitymentalhealththerapycenter.controller.DashboardController">
    <children>
        <VBox spacing="0" style="-fx-background-color: #f0fdf4;">

            <!-- ═══ HEADER ═══ -->
            <HBox alignment="CENTER_LEFT" prefHeight="65.0" spacing="12.0"
                  style="-fx-background-color: white; -fx-border-color: #d1fae5; -fx-border-width: 0 0 1.5 0;">
                <padding><Insets left="30.0" right="30.0" /></padding>
                <children>
                    <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                        <children>
                            <Label text="Dashboard" textFill="#064e3b">
                                <font><Font name="Arial Bold" size="22.0" /></font>
                            </Label>
                            <Label fx:id="lblCurrentDate" text="May 12, 2026" textFill="#6b7280">
                                <font><Font name="Arial" size="12.0" /></font>
                            </Label>
                        </children>
                    </VBox>
                    <HBox alignment="CENTER" prefHeight="36.0" prefWidth="210.0"
                          style="-fx-background-color: #f0fdf4; -fx-background-radius: 18; -fx-border-color: #a7f3d0; -fx-border-radius: 18; -fx-border-width: 1.5;">
                        <padding><Insets left="14.0" right="14.0" /></padding>
                        <children>
                            <Label text="🔍" style="-fx-font-size: 12px;" />
                            <Label text="  Search patients, sessions..." textFill="#9ca3af">
                                <font><Font name="Arial" size="11.0" /></font>
                            </Label>
                        </children>
                    </HBox>
                    <VBox alignment="CENTER" prefHeight="36.0" prefWidth="36.0"
                          style="-fx-background-color: #f0fdf4; -fx-background-radius: 18; -fx-border-color: #a7f3d0; -fx-border-radius: 18; -fx-border-width: 1.5; -fx-cursor: hand;">
                        <children>
                            <Label text="🔔" style="-fx-font-size: 14px;" />
                        </children>
                    </VBox>
                </children>
            </HBox>

            <!-- ═══ CONTENT ═══ -->
            <VBox spacing="20.0" VBox.vgrow="ALWAYS">
                <padding><Insets bottom="24.0" left="28.0" right="28.0" top="24.0" /></padding>
                <children>

                    <!-- Welcome Banner -->
                    <HBox alignment="CENTER_LEFT" prefHeight="85.0"
                          style="-fx-background-color: linear-gradient(to right, #10b981, #059669); -fx-background-radius: 14;">
                        <padding><Insets left="26.0" right="26.0" /></padding>
                        <children>
                            <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                <children>
                                    <Label fx:id="lblWelcome" text="Good Morning, Admin 👋" textFill="white">
                                        <font><Font name="Arial Bold" size="19.0" /></font>
                                    </Label>
                                    <Label text="Here's what's happening at Serenity today." textFill="#a7f3d0">
                                        <font><Font name="Arial" size="12.0" /></font>
                                    </Label>
                                </children>
                            </VBox>
                            <Label text="🌿" style="-fx-font-size: 44px; -fx-opacity: 0.55;" />
                        </children>
                    </HBox>

                    <!-- ═══ STAT CARDS ═══ -->
                    <GridPane hgap="16.0" vgap="16.0">
                        <columnConstraints>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="33.33" />
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="33.33" />
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="33.33" />
                        </columnConstraints>
                        <rowConstraints>
                            <RowConstraints minHeight="105.0" />
                            <RowConstraints minHeight="105.0" />
                        </rowConstraints>
                        <children>

                            <!-- Row 1 -->

                            <!-- Card: Total Patients -->
                            <VBox spacing="8.0" GridPane.columnIndex="0" GridPane.rowIndex="0"
                                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 4);">
                                <padding><Insets bottom="16.0" left="18.0" right="18.0" top="16.0" /></padding>
                                <children>
                                    <Label text="🧑‍⚕️" style="-fx-font-size: 22px;" />
                                    <Label fx:id="lblTotalPatients" text="0" textFill="#1f2937">
                                        <font><Font name="Arial Bold" size="26.0" /></font>
                                    </Label>
                                    <Label text="Total Patients" textFill="#6b7280">
                                        <font><Font name="Arial" size="12.0" /></font>
                                    </Label>
                                </children>
                            </VBox>

                            <!-- Card: Total Therapists -->
                            <VBox spacing="8.0" GridPane.columnIndex="1" GridPane.rowIndex="0"
                                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 4);">
                                <padding><Insets bottom="16.0" left="18.0" right="18.0" top="16.0" /></padding>
                                <children>
                                    <Label text="👨‍⚕️" style="-fx-font-size: 22px;" />
                                    <Label fx:id="lblTotalTherapists" text="0" textFill="#1f2937">
                                        <font><Font name="Arial Bold" size="26.0" /></font>
                                    </Label>
                                    <Label text="Total Therapists" textFill="#6b7280">
                                        <font><Font name="Arial" size="12.0" /></font>
                                    </Label>
                                </children>
                            </VBox>

                            <!-- Card: Active Programs -->
                            <VBox spacing="8.0" GridPane.columnIndex="2" GridPane.rowIndex="0"
                                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 4);">
                                <padding><Insets bottom="16.0" left="18.0" right="18.0" top="16.0" /></padding>
                                <children>
                                    <Label text="📋" style="-fx-font-size: 22px;" />
                                    <Label fx:id="lblTotalPrograms" text="0" textFill="#1f2937">
                                        <font><Font name="Arial Bold" size="26.0" /></font>
                                    </Label>
                                    <Label text="Active Programs" textFill="#6b7280">
                                        <font><Font name="Arial" size="12.0" /></font>
                                    </Label>
                                </children>
                            </VBox>

                            <!-- Row 2 -->

                            <!-- Card: Today's Sessions -->
                            <VBox spacing="8.0" GridPane.columnIndex="0" GridPane.rowIndex="1"
                                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 4);">
                                <padding><Insets bottom="16.0" left="18.0" right="18.0" top="16.0" /></padding>
                                <children>
                                    <Label text="📅" style="-fx-font-size: 22px;" />
                                    <Label fx:id="lblTodaySessions" text="0" textFill="#1f2937">
                                        <font><Font name="Arial Bold" size="26.0" /></font>
                                    </Label>
                                    <Label text="Today's Sessions" textFill="#6b7280">
                                        <font><Font name="Arial" size="12.0" /></font>
                                    </Label>
                                </children>
                            </VBox>

                            <!-- Card: Pending Payments -->
                            <VBox spacing="8.0" GridPane.columnIndex="1" GridPane.rowIndex="1"
                                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 4);">
                                <padding><Insets bottom="16.0" left="18.0" right="18.0" top="16.0" /></padding>
                                <children>
                                    <Label text="💳" style="-fx-font-size: 22px;" />
                                    <Label fx:id="lblPendingPayments" text="0" textFill="#1f2937">
                                        <font><Font name="Arial Bold" size="26.0" /></font>
                                    </Label>
                                    <Label text="Pending Payments" textFill="#6b7280">
                                        <font><Font name="Arial" size="12.0" /></font>
                                    </Label>
                                </children>
                            </VBox>

                            <!-- Card: Monthly Revenue -->
                            <VBox spacing="8.0" GridPane.columnIndex="2" GridPane.rowIndex="1"
                                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 4);">
                                <padding><Insets bottom="16.0" left="18.0" right="18.0" top="16.0" /></padding>
                                <children>
                                    <Label text="💰" style="-fx-font-size: 22px;" />
                                    <Label fx:id="lblMonthlyRevenue" text="LKR 0" textFill="#1f2937">
                                        <font><Font name="Arial Bold" size="22.0" /></font>
                                    </Label>
                                    <Label text="Monthly Revenue" textFill="#6b7280">
                                        <font><Font name="Arial" size="12.0" /></font>
                                    </Label>
                                </children>
                            </VBox>

                        </children>
                    </GridPane>

                    <!-- ═══ QUICK ACTIONS ═══ -->
                    <VBox spacing="12.0"
                          style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 4);"
                          VBox.vgrow="ALWAYS">
                        <padding><Insets bottom="20.0" left="22.0" right="22.0" top="16.0" /></padding>
                        <children>
                            <Label text="Quick Actions" textFill="#064e3b">
                                <font><Font name="Arial Bold" size="15.0" /></font>
                            </Label>
                            <HBox spacing="14.0" VBox.vgrow="ALWAYS">
                                <children>
                                    <Button fx:id="btnQuickRegister"
                                            maxWidth="1.7976931348623157E308" maxHeight="1.7976931348623157E308"
                                            style="-fx-background-color: #ecfdf5; -fx-background-radius: 10; -fx-text-fill: #059669; -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand; -fx-border-color: #a7f3d0; -fx-border-radius: 10;"
                                            text="➕  Register Patient" HBox.hgrow="ALWAYS">
                                        <font><Font name="Arial Bold" size="13.0" /></font>
                                    </Button>
                                    <Button fx:id="btnQuickSchedule"
                                            maxWidth="1.7976931348623157E308" maxHeight="1.7976931348623157E308"
                                            style="-fx-background-color: #ecfdf5; -fx-background-radius: 10; -fx-text-fill: #059669; -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand; -fx-border-color: #a7f3d0; -fx-border-radius: 10;"
                                            text="📅  New Session" HBox.hgrow="ALWAYS">
                                        <font><Font name="Arial Bold" size="13.0" /></font>
                                    </Button>
                                    <Button fx:id="btnQuickPayment"
                                            maxWidth="1.7976931348623157E308" maxHeight="1.7976931348623157E308"
                                            style="-fx-background-color: #ecfdf5; -fx-background-radius: 10; -fx-text-fill: #059669; -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand; -fx-border-color: #a7f3d0; -fx-border-radius: 10;"
                                            text="💳  Process Payment" HBox.hgrow="ALWAYS">
                                        <font><Font name="Arial Bold" size="13.0" /></font>
                                    </Button>
                                    <Button fx:id="btnQuickReport"
                                            maxWidth="1.7976931348623157E308" maxHeight="1.7976931348623157E308"
                                            style="-fx-background-color: #ecfdf5; -fx-background-radius: 10; -fx-text-fill: #059669; -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand; -fx-border-color: #a7f3d0; -fx-border-radius: 10;"
                                            text="📊  Generate Report" HBox.hgrow="ALWAYS">
                                        <font><Font name="Arial Bold" size="13.0" /></font>
                                    </Button>
                                </children>
                            </HBox>
                        </children>
                    </VBox>

                </children>
            </VBox>

        </VBox>
    </children>
</StackPane>